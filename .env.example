# =============================================================================
# 工业故障自愈 Multi-Agent 系统 — 环境变量模板
# 复制为 .env 并填入实际值:  cp .env.example .env
# =============================================================================

# --- DeepSeek API (required) ---
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# --- HuggingFace 模型缓存目录 (可选，默认 ~/.cache/huggingface) ---
HF_CACHE_DIR=/home/iisc/.cache/huggingface

# --- DingTalk 通知 Webhook (可选) ---
# DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx

# --- 真实中间件连接 (docker-compose 自动提供，无需修改) ---
# REDIS_HOST=redis-real
# REDIS_PORT=6379
# REDIS_PASSWORD=dev-pass
# MYSQL_HOST=mysql-real
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=dev-pass
# MYSQL_DATABASE=industrial_db

# --- API 认证 (开发环境，生产请更换) ---
API_KEY=dev-key-change-me
